# ============================================================
# AMR-LM: .gitignore
# ============================================================

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Virtual Environments ────────────────────────────────────
venv/
env/
.venv/
.env/

# ── IDE / Editor ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ── OS Files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ─────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Data (too large; regenerated by pipeline) ───────────────
data/raw/
data/processed/
data/splits/
history.db
card-data.tar.bz2

# ── Model Weights (too large for GitHub; ~468 MB each) ──────
models/

# ── Generated Results (reproducible via pipeline) ───────────
results/figures/*.png
results/pipeline.log
results/roc_data.json

# ── External Databases (downloaded by setup script) ─────────
card-data/

# ── Large / Unnecessary Files ───────────────────────────────
*.bin
*.pt
*.pth
*.ckpt
*.h5
*.hdf5
*.fasta
*.fa
*.fna
*.fastq
*.fq
*.bam
*.sam
*.vcf
*.gz
*.tar
*.zip
*.7z
*.rar

# ── Images (generated by pipeline) ──────────────────────────
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.svg

# ── Installer / Unrelated Files ─────────────────────────────
*.exe
*.msi
*.vitalbank
FactoryContent.vitalbank
VitalInstaller.exe

# ── Logs ────────────────────────────────────────────────────
*.log
logs/
